{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "ignoreDeprecations": "6.0",
    "rootDir": "src",
    "outDir": "dist",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": false,
    "noImplicitAny": false,
    "useUnknownInCatchVariables": false,
    "skipLibCheck": true,
    "types": [
      "node",
      "express"
    ],
    "baseUrl": ".",
    "paths": {
      "@movies-explorer/shared": [
        "../../packages/shared/src"
      ]
    }
  },
  "include": [
    "src"
  ]
}
